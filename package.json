{
  "name": "@beamit/extension",
  "version": "0.1.0",
  "description": "Chrome扩展：抓取网页视频流并投屏到电视",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run && allure generate",
    "test:open": "allure open",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chrome-extension",
    "casting",
    "dlna",
    "video"
  ],
  "author": "yaoshining",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yaoshining/beamit.git"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "autoprefixer": "^10.4.0",
    "plasmo": "^0.89.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.4.0",
    "allure-commandline": "^2.29.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.4.0"
  }
}
