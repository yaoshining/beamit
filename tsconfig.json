{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@background/*": [
        "src/background/*"
      ],
      "@content/*": [
        "src/content/*"
      ],
      "@popup/*": [
        "src/popup/*"
      ],
      "@background-utils/*": [
        "src/background-utils/*"
      ]
    },
    "types": [
      "chrome",
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    ".plasmo/index.d.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".plasmo/static/**/*"
  ]
}
